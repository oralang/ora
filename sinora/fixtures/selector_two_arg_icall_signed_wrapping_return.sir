fn init:
    entry {
        v0 = runtime_start_offset
        v1 = runtime_length
        v2 = malloc v1
        codecopy v2 v0 v1
        return v2 v1
    }

fn add_wrap:
    entry v0 v1 -> v8 v2 {
        v2 = const 0x20
        v3 = const 0x0
        v4 = const 0xFF
        v5 = add v0 v1
        v6 = and v5 v4
        v7 = signextend v3 v6
        v8 = malloc v2
        mstore256 v8 v7
        iret
    }

