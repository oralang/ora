fn wrapping_sub_u8:
    entry v0 v1 -> v7 v2 {
        v2 = const 0x20
        v3 = const 0xFF
        v4 = sub v0 v1
        v5 = and v4 v3
        v6 = and v5 v3
        v7 = malloc v2
