fn init:
    entry {
        v0 = runtime_start_offset
        v1 = runtime_length
        v2 = malloc v1
        codecopy v2 v0 v1
        return v2 v1
    }

fn wrapping_add_u8:
    entry v0 v1 -> v7 v2 {
        v2 = const 0x20
        v3 = const 0xFF
        v4 = add v0 v1
        v5 = and v4 v3
        v6 = and v5 v3
        v7 = malloc v2
        mstore256 v7 v6
        iret
