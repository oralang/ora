fn testImplicitStorageInReturn:
    entry -> v1 v0 {
        v0 = const 0x20
        slot_counter = const 0x0
        value = sload slot_counter
        v1 = malloc v0
        mstore256 v1 value
        iret
    }

fn testImplicitStorageMap:
    entry v0 {
        iret
