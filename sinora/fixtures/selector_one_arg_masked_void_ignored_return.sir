fn init:
    entry {
        v0 = runtime_start_offset
        v1 = runtime_length
        v2 = malloc v1
        codecopy v2 v0 v1
        return v2 v1
    }

fn testImplicitStorageToStack:
    entry {
        iret
    }

fn testImplicitStorageInArithmetic:
    entry {
        iret
    }

fn testImplicitStorageInComparison:
    entry {
        iret
