fn init:
    entry {
        start = runtime_start_offset
        len = runtime_length
        ptr = malloc len
        codecopy ptr start len
        return ptr len
    }

fn main:
    entry {
        ptr = const 0x0
        len = const 0x20
        value = const 0x2a
        noop
        copied = copy value
        mstore256 ptr copied
        return ptr len
    }
