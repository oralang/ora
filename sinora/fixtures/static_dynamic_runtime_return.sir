fn init:
    entry {
        start = runtime_start_offset
        len = runtime_length
        ptr = malloc len
        codecopy ptr start len
        return ptr len
    }

fn main:
    entry {
        static = sallocany 0x40
        len = const 0x20
        dynamic = mallocany len
        value = const 0x2a
        mstore256 dynamic value
        return static len
    }
