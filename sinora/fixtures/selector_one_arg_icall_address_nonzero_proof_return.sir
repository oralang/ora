        a_g = calldataload selector_offset_0
        v4 = large_const 0xFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF
        v5 = and a_g v4
        v6 = eq a_g v5
        v7 = const 0x0
        v8 = eq v5 v7
        v9 = iszero v8
        => v6 ? @bb1 : @abi_decode_revert_5
    }
    g_exec {
        v12 v13 = icall @g v5
        return v12 v13
