        v2 = const 0x1
        c0 = const 0x0
        v3 = large_const 0xFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF
        v4 = and v0 v3
        v5 = eq v4 c0
        v6 = xor v5 v2
        v7 = iszero v6
        v8 = iszero v7
        => v8 ? @bb1 : @bb0
