fn init:
    entry {
        start = runtime_start_offset
        len = runtime_length
        ptr = malloc len
        codecopy ptr start len
        return ptr len
    }

fn main:
    entry {
        ptr = const 0x0
        len = const 0x20
        value = const 0xab
        mstore8 ptr value
        loaded = mload8 ptr
        mstore256 ptr loaded
        return ptr len
    }
