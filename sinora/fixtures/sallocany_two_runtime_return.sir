fn init:
    entry {
        start = runtime_start_offset
        len = runtime_length
        ptr = malloc len
        codecopy ptr start len
        return ptr len
    }

fn main:
    entry {
        first = sallocany 0x20
        second = sallocany 0x4
        len = const 0x20
        value = const 0x2a
        mstore256 second value
        return first len
    }
