fn init:
    entry {
        start = runtime_start_offset
        len = runtime_length
        ptr = malloc len
        codecopy ptr start len
        return ptr len
    }

fn main:
    entry {
        len = const 0x20
        src = sallocany 0x20
        dst = sallocany 0x20
        value = const 0x2a
        mstore256 src value
        mcopy dst src len
        return dst len
    }
