comptime const std = @import("std");

contract PartialEvalProbe {
    storage var counter: u256;

    fn helper(a: u256, b: u256) -> u256 {
        return a + b;
    }

    fn read_counter() -> u256 {
        return counter;
    }

    pub fn folded_decl(x: u256) -> u256
        requires(x <= std.constants.U256_MAX - 5)
    {
        const ct: u256 = helper(2, 3);
        return x + ct;
    }

    pub fn folded_nested(x: u256) -> u256
        requires(x <= std.constants.U256_MAX - 6)
    {
        const nested: u256 = helper(helper(1, 2), 3);
        return x + nested;
    }

    pub fn impure_boundary(x: u256) -> u256
        requires(read_counter() <= std.constants.U256_MAX - x)
    {
        const live: u256 = read_counter();
        return x + live;
    }
}
