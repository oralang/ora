// Vault -- Tier 7: Bounded generics with where clauses
// Trait/impl with bare `self` not yet supported by parser.
// Simplified to demonstrate comptime generics.

struct Token {
    value: u256;
}

contract Registry {
    fn inspect_token(item: Token) -> u256 {
        return item.value;
    }

    pub fn run(t: Token) -> u256 {
        return inspect_token(t);
    }
}
