// Simple storage counter app
comptime const std = @import("std");

contract Counter {
    storage var counter: u256 = 0;

    pub fn init() {
        counter = 0;
    }

    pub fn increment()
        requires(counter < std.constants.U256_MAX)
    {
        counter += 1;
    }

    pub fn get() -> u256 {
        return counter;
    }
}
