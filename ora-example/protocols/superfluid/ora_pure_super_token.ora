// Ora-native Pure SuperToken, phase 1.
//
// This intentionally models the Superfluid settled-balance core without ERC777
// hooks/operators, an underlying wrapper, permit, proxies, or agreement logic.
// The distinguishing state is signed settled balances; the public ERC20 view
// exposes only the positive available balance.

error InsufficientAllowance(required: u256, available: u256);
error InsufficientBalance(required: u256, available: u256);
error SignedBalanceOverflow;

comptime const std = @import("std");

// Superfluid settled balances are i256. Amounts that become signed deltas must
// fit in i256.max before they can be added to or subtracted from settled state.
type SuperTokenAmount = InRange<u256, 1, std.constants.I256_MAX>;
type InitialSupply = InRange<u256, 1, std.constants.I256_MAX>;
type Account = NonZeroAddress;
type Recipient = NonZeroAddress;
type Spender = NonZeroAddress;

// A settled balance is signed (Superfluid semantics); the spendable ("available")
// balance is its non-negative part. The signed-balance rules live on the type via
// a trait instead of free contract helpers, so the behavior travels with the value.
trait SettledBalance {
    fn available(self) -> u256;
}

struct Settled {
    value: i256,
}

impl SettledBalance for Settled {
    fn available(self) -> u256 {
        if (self.value <= 0) {
            return 0;
        }
        return @cast(u256, self.value);
    }
}
/*
contract OraPureSuperToken {
