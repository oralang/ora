    pub fn transfer(to: Recipient, amount: SuperTokenAmount) -> !bool|InsufficientBalance|SignedBalanceOverflow
    modifies shared_settled_balances[msg.sender], shared_settled_balances[to]
    {
        let sender: NonZeroAddress = std.msg.sender();
        let delta: i256 = amountDelta(amount);
        let sender_before: i256 = shared_settled_balances[sender];
        let sender_settled: Settled = .{
            .value = sender_before
