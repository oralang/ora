    pub fn transferFrom(from: Account, to: Recipient, amount: SuperTokenAmount) -> !bool|InsufficientAllowance|InsufficientBalance|SignedBalanceOverflow
    modifies allowances[from][msg.sender], shared_settled_balances[from], shared_settled_balances[to]
    {
        let spender: NonZeroAddress = std.msg.sender();
        let current_allowance: u256 = allowances[from][spender];
        if (current_allowance<amount) {
            return InsufficientAllowance(amount, current_allowance);
