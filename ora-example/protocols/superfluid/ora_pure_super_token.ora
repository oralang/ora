        agreement_data_hash[agreement_class][id] = data_hash;
        agreement_data_length[agreement_class][id] = data_length;

        log AgreementUpdated(agreement_class, id, data_length);
        return true;
    }

    pub fn terminateAgreement(id: bytes32, data_length: u256) -> !bool|AgreementDoesNotExist|AgreementDataLengthMismatch
    modifies agreement_exists[msg.sender][id], agreement_data_length[msg.sender][id]
    {
        let agreement_class: NonZeroAddress = std.msg.sender();
        if (!agreement_exists[agreement_class][id]) {
            return AgreementDoesNotExist;
        }
        if (agreement_data_length[agreement_class][id] != data_length) {
            return AgreementDataLengthMismatch;
        }

        agreement_exists[agreement_class][id] = false;
        agreement_data_length[agreement_class][id] = 0;

        log AgreementTerminated(agreement_class, id);
        return true;
    }

    pub fn updateAgreementStateSlot(account: Account, slot_id: u256, state_hash: bytes32, data_length: u256) -> bool
