        shared_settled_balances[sender] = sender_before - delta;
        shared_settled_balances[to] = to_before + delta;

        log Transfer(sender, to, amount);
        return true;
    }

    pub fn approve(spender: Spender, amount: u256) -> bool
    modifies allowances[msg.sender][spender]
    {
        let owner: NonZeroAddress = std.msg.sender();
        allowances[owner][spender] = amount;
        log Approval(owner, spender, amount);
        return true;
