        }

        let to_before: i256 = shared_settled_balances[to];
        if (to_before>std.constants.I256_MAX - delta) {
            return SignedBalanceOverflow;
        }

        allowances[from][spender] = current_allowance - amount;
        shared_settled_balances[from] = from_before - delta;
        shared_settled_balances[to] = to_before + delta;

        log Transfer(from, to, amount);
        return true;
    }

    pub fn createAgreement(id: bytes32, data_hash: bytes32, data_length: u256) -> !bool|AgreementAlreadyExists
    modifies agreement_exists[msg.sender][id], agreement_data_hash[msg.sender][id], agreement_data_length[msg.sender][id]
    {
        let agreement_class: NonZeroAddress = std.msg.sender();
        if (agreement_exists[agreement_class][id]) {
            return AgreementAlreadyExists;
        }

        agreement_exists[agreement_class][id] = true;
        agreement_data_hash[agreement_class][id] = data_hash;
        agreement_data_length[agreement_class][id] = data_length;

        log AgreementCreated(agreement_class, id, data_length);
        return true;
    }

    pub fn getAgreementDataLength(agreement_class: AgreementClass, id: bytes32) -> !u256|AgreementDoesNotExist
    {
        if (!agreement_exists[agreement_class][id]) {
            return AgreementDoesNotExist;
        }

        return agreement_data_length[agreement_class][id];
    }

    pub fn getAgreementDataHash(agreement_class: AgreementClass, id: bytes32) -> !bytes32|AgreementDoesNotExist
    {
        if (!agreement_exists[agreement_class][id]) {
            return AgreementDoesNotExist;
        }

        return agreement_data_hash[agreement_class][id];
    }

    pub fn updateAgreementData(id: bytes32, data_hash: bytes32, data_length: u256) -> !bool|AgreementDoesNotExist
    modifies agreement_data_hash[msg.sender][id], agreement_data_length[msg.sender][id]
    {
        let agreement_class: NonZeroAddress = std.msg.sender();
        if (!agreement_exists[agreement_class][id]) {
            return AgreementDoesNotExist;
