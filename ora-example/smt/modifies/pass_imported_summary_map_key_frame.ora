comptime const dep = @import("./pass_imported_summary_map_key_frame_dep.ora");

contract ImportedSummaryFrame {
    storage var balances: map<address, u256>;

    pub fn f(user: address, other: address, value: u256) -> bool
        requires(user != other)
        ensures(balances[other] == old(balances[other]))
    {
        dep.set_balance(user, value);
        return true;
    }
}
