resource TokenUnit = u256;
comptime const std = @import("std");

contract ResourceSmtFailGlobalSupplyConservationUnstated {
    storage var balance: Resource<TokenUnit>;
    storage var total_supply: TokenUnit;

    pub fn issue(amount: TokenUnit)
        modifies balance
        requires balance <= @cast(TokenUnit, std.constants.U256_MAX) - amount
        ensures balance == total_supply
    {
        @create(balance, amount);
    }
}
