resource TokenUnit = u256;
comptime const std = @import("std");

contract ResourceSmtCreateDestroySupplyDelta {
    storage var balance: Resource<TokenUnit>;
    storage var total_supply: TokenUnit;

    pub fn issue(amount: TokenUnit)
        modifies balance, total_supply
        requires balance <= @cast(TokenUnit, std.constants.U256_MAX) - amount
        requires total_supply <= @cast(TokenUnit, std.constants.U256_MAX) - amount
        ensures balance == old(balance) + amount
        ensures total_supply == old(total_supply) + amount
    {
        @create(balance, amount);
        total_supply += amount;
    }

    pub fn retire(amount: TokenUnit)
        modifies balance, total_supply
        requires balance >= amount
        requires total_supply >= amount
        ensures balance == old(balance) - amount
        ensures total_supply == old(total_supply) - amount
    {
        @destroy(balance, amount);
        total_supply -= amount;
    }
}
