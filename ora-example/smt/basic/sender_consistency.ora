comptime const std = @import("std");

contract SenderConsistency {
    pub fn f() -> bool
        ensures std.msg.sender() == std.msg.sender()
    {
        let s1: NonZeroAddress = std.msg.sender();
        let s2: NonZeroAddress = std.msg.sender();

        if (s1 == s2) {
            return true;
        }

        return false;
    }
}
