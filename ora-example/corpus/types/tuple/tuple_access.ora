// Access tuple elements with .0, .1, etc.

contract TupleAccess {
    pub fn access_two() -> u256 {
        let t: (u256, u256) = (100, 200);
        let first: u256 = t.0;
        let second: u256 = t.1;
        return first + second;
    }

    pub fn access_in_expression() -> u256 {
        let t: (u256, u256) = (5, 10);
        return t.0 * t.1;
    }

    pub fn access_bool() -> bool {
        let t: (u256, bool) = (1, true);
        return t.1;
    }
}
