error Failure(code: u256);

pub contract ResultBytesFlow {
    pub fn inspect(value: Result<bytes, Failure>, flag: bool) -> u256 {
        match (value) {
            Ok(inner) => {
                if (flag) {
                    return 1;
                }
                return 11;
            },
            Err(err) => {
                return err.code;
            }
        }
    }
}
