error Failure(code: u256);
error Denied(owner: address);

pub contract ResultErrDiscard {
    fn decide(flag: bool) -> !u256 | Failure | Denied {
        if (flag) {
            return 10;
        }
        return Failure(7);
    }

    pub fn project(flag: bool) -> u256 {
        return match (decide(flag)) {
            Ok(_) => 1,
            Err(_) => 2,
        };
    }
}
