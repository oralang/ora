contract BitNot {
    pub fn not_u8(x: u8) -> u8 {
        let result: u8 = ~x;
        return result;
    }

    pub fn not_u16(x: u16) -> u16 {
        let result: u16 = ~x;
        return result;
    }

    pub fn not_u32(x: u32) -> u32 {
        let result: u32 = ~x;
        return result;
    }

    pub fn not_u64(x: u64) -> u64 {
        let result: u64 = ~x;
        return result;
    }

    pub fn not_u128(x: u128) -> u128 {
        let result: u128 = ~x;
        return result;
    }

    pub fn not_u256(x: u256) -> u256 {
        let result: u256 = ~x;
        return result;
    }

    pub fn double_not_u256(x: u256) -> u256 {
        let result: u256 = ~(~x);
        return result;
    }
}
