contract SignedComparison {
    pub fn lt_i8(a: i8, b: i8) -> bool {
        let result: bool = a < b;
        return result;
    }

    pub fn le_i8(a: i8, b: i8) -> bool {
        let result: bool = a <= b;
        return result;
    }

    pub fn gt_i8(a: i8, b: i8) -> bool {
        let result: bool = a > b;
        return result;
    }

    pub fn ge_i8(a: i8, b: i8) -> bool {
        let result: bool = a >= b;
        return result;
    }

    pub fn lt_i256(a: i256, b: i256) -> bool {
        let result: bool = a < b;
        return result;
    }

    pub fn le_i256(a: i256, b: i256) -> bool {
        let result: bool = a <= b;
        return result;
    }

    pub fn gt_i256(a: i256, b: i256) -> bool {
        let result: bool = a > b;
        return result;
    }

    pub fn ge_i256(a: i256, b: i256) -> bool {
        let result: bool = a >= b;
        return result;
    }
}
