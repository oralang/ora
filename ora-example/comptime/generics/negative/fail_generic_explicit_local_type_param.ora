contract FailGenericExplicitLocalTypeParam {
    fn add_one(comptime T: type, x: T) -> T {
        var y: T = x;
        return y + 1;
    }

    // INVALID: generic helper checked arithmetic is reachable from a public caller
    // with no precondition constraining overflow.
    pub fn bad(x: u256) -> u256 {
        return add_one(u256, x);
    }
}
