error Failure(code: u256, data: bytes);

contract AbiDecodeResultMultiErrorPayloadRevert {
    storage var touched: u256 = 0;

    pub fn consume(value: Result<u256, Failure>) -> u256 {
        touched = 12;
        return match(value) {
            Ok(inner) -> inner,
            Err(err) -> err.code + err.data.len,
        };
    }
}
