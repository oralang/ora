contract ScalarLoopPost {
    pub fn countTo(n: u256) -> u256
        ensures result <= n
    {
        var i: u256 = 0;
        while (i < n)
            invariant i <= n
        {
            i = i + 1;
        }
        return i;
    }

    pub fn guarded(value: u256) -> bool
        guard value > 0
    {
        return true;
    }
}
