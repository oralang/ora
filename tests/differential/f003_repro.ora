// see FINDINGS.md#f-003 (differential repro; kept out of tests/conformance)
// see FINDINGS.md#f-002 (err_default catch path excluded from spec)
error Failure;

struct Pair {
    lo: u256;
    hi: u256;
}

contract ErrorUnionWideCarrier {
    fn make(flag: bool) -> !Pair | Failure {
        if (flag) {
            return Pair { lo: 11, hi: 22 };
        }
        return Failure;
    }

    pub fn ok_lo() -> u256 {
        try {
            let p: Pair = try make(true);
            return p.lo;
        } catch (e) {
            return 0;
        }
    }

    pub fn ok_hi() -> u256 {
        try {
            let p: Pair = try make(true);
            return p.hi;
        } catch (e) {
            return 0;
        }
    }

    pub fn err_default() -> u256 {
        try {
            let p: Pair = try make(false);
            return p.lo;
        } catch (e) {
            return 777;
        }
    }
}
