// INPUT: tests/conformance/resource_failure_atomicity.ora
// CHECK-NOT: builtin.unrealized_conversion_cast

// CHECK-LABEL: fn transferUnchecked:
// CHECK: hash_balances = keccak256
// CHECK: hash_balances_0 = keccak256
// CHECK: [[SAME:v[0-9]+]] = eq hash_balances hash_balances_0
// CHECK: => [[SAME]] ? @bb0 : @bb3
// CHECK: bb3 {
// CHECK: [[SRC:v[0-9]+]] = sload hash_balances
// CHECK: [[DST:v[0-9]+]] = sload hash_balances_0
// CHECK: [[SRC_AFTER:v[0-9]+]] = sub [[SRC]] v2
// CHECK: [[SRC_UNDERFLOW:v[0-9]+]] = lt [[SRC]] v2
// CHECK: [[SRC_OK:v[0-9]+]] = iszero [[SRC_UNDERFLOW]]
// CHECK: => [[SRC_OK]] ? @bb4 : @bb1
// CHECK: [[DST_AFTER:v[0-9]+]] = add [[DST]] v2
// CHECK: [[DST_OVERFLOW:v[0-9]+]] = lt [[DST_AFTER]] [[DST]]
// CHECK: [[DST_OK:v[0-9]+]] = iszero [[DST_OVERFLOW]]
// CHECK: => [[DST_OK]] ? @bb5 : @bb1
// CHECK: sstore hash_balances [[SRC_AFTER]]
// CHECK: sstore hash_balances_0 [[DST_AFTER]]
