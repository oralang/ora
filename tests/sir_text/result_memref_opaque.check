// INPUT: tests/conformance/result_memref_opaque.ora
// CHECK-NOT: builtin.unrealized_conversion_cast

// CHECK-LABEL: fn choose:
// CHECK: iret

// CHECK-LABEL: fn run:
// CHECK: alloc_size = const 0x40
// CHECK: arr_base = malloc alloc_size
// CHECK: v[[TAG:[0-9]+]] v[[PAYLOAD:[0-9]+]] = icall @choose
// CHECK: v[[MASKED_TAG:[0-9]+]] = and v[[TAG]] c1
// CHECK: v[[IS_ERR:[0-9]+]] = eq v[[MASKED_TAG]] c1
// CHECK: v[[SHIFTED:[0-9]+]] = shl c1 v[[PAYLOAD]]
// CHECK: v[[PACKED:[0-9]+]] = or v[[SHIFTED]] v[[IS_ERR]]
// CHECK: mstore256 elem2_ptr v[[PACKED]]
// CHECK: elem4 = mload256
// CHECK: v[[LOADED_TAG:[0-9]+]] = and elem4 c1
// CHECK: v[[OK_VALUE:[0-9]+]] = shr v21 elem4
