// INPUT: tests/sir_text/inputs/abi_decode_wide_result_sink.ora
// CHECK-NOT: builtin.unrealized_conversion_cast

// CHECK-LABEL: fn roundtrip:
// CHECK: mstore256 {{.*}} v0
// CHECK: {{v[0-9]+}} = mload256
// CHECK: {{v[0-9]+}} = lt {{v[0-9]+}} {{v[0-9]+}}
// CHECK: bb0 -> v[[RT_ERR_TAG:[0-9]+]] v[[RT_ERR_PAYLOAD:[0-9]+]] {
// CHECK-NEXT: v[[RT_ERR_PAYLOAD]] = const 0x0
// CHECK-NEXT: v[[RT_ERR_TAG]] = const 0x1
// CHECK: bb1 -> v[[RT_OK_TAG:[0-9]+]] v[[RT_OK_PAYLOAD:[0-9]+]] {
// CHECK: v[[RT_OK_TAG]] = or
// CHECK: v[[RT_OK_PAYLOAD]] = or
// CHECK: bb2 v[[RT_TAG:[0-9]+]] v[[RT_PAYLOAD:[0-9]+]] {
// CHECK: {{v[0-9]+}} = and v[[RT_TAG]] {{.*}}
// CHECK: bb4 -> v[[RT_PAYLOAD]] {
// CHECK: bb5 v[[RT_SELECTED_PAYLOAD:[0-9]+]] ->
// CHECK: mstore256 {{.*}} v[[RT_SELECTED_PAYLOAD]]
// CHECK: iret

// CHECK-LABEL: fn malformed:
// CHECK: {{v[0-9]+}} = mload256 v0
// CHECK: {{v[0-9]+}} = lt {{v[0-9]+}} {{v[0-9]+}}
// CHECK: bb0 -> v[[BAD_ERR_TAG:[0-9]+]] v[[BAD_ERR_PAYLOAD:[0-9]+]] {
// CHECK-NEXT: v[[BAD_ERR_PAYLOAD]] = const 0x0
// CHECK-NEXT: v[[BAD_ERR_TAG]] = const 0x1
// CHECK: bb1 -> v[[BAD_OK_TAG:[0-9]+]] v[[BAD_OK_PAYLOAD:[0-9]+]] {
// CHECK: v[[BAD_OK_TAG]] = or
// CHECK: v[[BAD_OK_PAYLOAD]] = or
// CHECK: bb2 v[[BAD_TAG:[0-9]+]] v[[BAD_PAYLOAD:[0-9]+]] {
// CHECK: {{v[0-9]+}} = and v[[BAD_TAG]] {{.*}}
// CHECK: {{v[0-9]+}} = const 0x1
// CHECK: iret
