// INPUT: ora-example/corpus/resources/signed_resource_negative_balance.ora
// CHECK-LABEL: ora.contract @ResourceSignedNegativeBalance
// CHECK: ora.global "pending" : i256
// CHECK: ora.global "settled" : i256

// CHECK-LABEL: func.func @seed
// CHECK-SAME: ora.modifies_slots = ["pending"]
// CHECK: arith.cmpi sge
// CHECK: "ora.create"
// CHECK-SAME: carrier_signed = true
// CHECK-SAME: carrier_type = i256
// CHECK-SAME: domain = "DebtUnit"

// CHECK-LABEL: func.func @settle
// CHECK-SAME: ora.modifies_slots = ["pending", "settled"]
// CHECK-SAME: ora.read_slots = ["pending", "settled"]
// CHECK-SAME: ora.write_slots = ["pending", "settled"]
// CHECK: arith.cmpi sge
// CHECK: "ora.move"
// CHECK-SAME: carrier_signed = true
// CHECK-SAME: carrier_type = i256
// CHECK-SAME: domain = "DebtUnit"
// CHECK-SAME: operandSegmentSizes = array<i32: 1, 1, 1>
