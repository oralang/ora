// INPUT: tests/conformance/resource_basic_transfer.ora
// CHECK-LABEL: ora.contract @ResourceBasicTransfer
// CHECK: ora.global "balances" : !ora.map<!ora.address, i256>

// CHECK-LABEL: func.func @issue
// CHECK-SAME: ora.effect = "readwrites"
// CHECK-SAME: ora.read_slots = ["balances[param#0]"]
// CHECK-SAME: ora.write_slots = ["balances[param#0]"]
// CHECK: "ora.create"
// CHECK-SAME: carrier_signed = false
// CHECK-SAME: carrier_type = i256
// CHECK-SAME: domain = "TokenUnit"

// CHECK-LABEL: func.func @transfer
// CHECK-SAME: ora.read_slots = ["balances[param#0]", "balances[param#1]"]
// CHECK-SAME: ora.write_slots = ["balances[param#0]", "balances[param#1]"]
// CHECK: "ora.move"
// CHECK-SAME: carrier_signed = false
// CHECK-SAME: carrier_type = i256
// CHECK-SAME: domain = "TokenUnit"
// CHECK-SAME: operandSegmentSizes = array<i32: 2, 2, 1>

// CHECK-LABEL: func.func @retire
// CHECK-SAME: ora.read_slots = ["balances[param#0]"]
// CHECK-SAME: ora.write_slots = ["balances[param#0]"]
// CHECK: "ora.destroy"
// CHECK-SAME: carrier_signed = false
// CHECK-SAME: carrier_type = i256
// CHECK-SAME: domain = "TokenUnit"
