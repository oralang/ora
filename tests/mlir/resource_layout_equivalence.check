// INPUT: ora-example/corpus/resources/resource_layout_equivalence.ora
// CHECK-LABEL: ora.contract @ResourceLayoutEquivalence
// CHECK: ora.global "raw_balances" : !ora.map<!ora.address, i256>
// CHECK: ora.global "resource_balances" : !ora.map<!ora.address, i256>

// CHECK-LABEL: func.func @write_raw
// CHECK-SAME: ora.modifies_slots = ["raw_balances[param#0]"]
// CHECK: ora.map_store

// CHECK-LABEL: func.func @issue_resource
// CHECK-SAME: ora.modifies_slots = ["resource_balances[param#0]"]
// CHECK: "ora.create"
// CHECK-SAME: carrier_signed = false
// CHECK-SAME: carrier_type = i256
// CHECK-SAME: domain = "TokenUnit"

// CHECK-LABEL: func.func @rawBalance
// CHECK-SAME: ora.read_slots = ["raw_balances"]
// CHECK-LABEL: func.func @resourceBalance
// CHECK-SAME: ora.read_slots = ["resource_balances"]
