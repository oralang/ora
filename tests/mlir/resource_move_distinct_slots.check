// INPUT: ora-example/corpus/resources/distinct_roots_transfer.ora
// CHECK-LABEL: ora.contract @ResourceDistinctRootsTransfer
// CHECK: ora.global "pending" : !ora.map<!ora.address, i256>
// CHECK: ora.global "settled" : !ora.map<!ora.address, i256>

// CHECK-LABEL: func.func @settle
// CHECK-SAME: ora.effect = "readwrites"
// CHECK-SAME: ora.read_slots = ["pending[param#0]", "settled[param#1]"]
// CHECK-SAME: ora.write_slots = ["pending[param#0]", "settled[param#1]"]
// CHECK: %pending
// CHECK-SAME: ora.sload "pending"
// CHECK: %settled
// CHECK-SAME: ora.sload "settled"
// CHECK: "ora.move"
// CHECK-SAME: carrier_signed = false
// CHECK-SAME: carrier_type = i256
// CHECK-SAME: domain = "TokenUnit"
// CHECK-SAME: operandSegmentSizes = array<i32: 2, 2, 1>

// CHECK-LABEL: func.func @pendingOf
// CHECK-SAME: ora.read_slots = ["pending[param#0]"]
// CHECK-LABEL: func.func @settledOf
// CHECK-SAME: ora.read_slots = ["settled[param#0]"]
