// Events depth (smaller gap): a multi-field event. see FINDINGS.md#f-008 —
// Ora emits topics=[] (no topic0 signature hash), all fields packed in data.
contract EventsMultifield {
    log Recorded(who: address, amount: u256);

    pub fn record(who: address, amount: u256) {
        log Recorded(who, amount);
    }
}
