// TWO FINDINGS (execution-pinned 2026-06-11):
// 1. Tuple returns from inside try/catch blocks fail OraToSIR Phase3b
//    legalization (unresolved !ora.tuple<i256, !ora.string> -> !sir.ptr<1>),
//    so the try/catch paths assert via .len only.
// 2. The catch path after `try` on an error union with an aggregate payload
//    (string here, wide struct in error_union_wide_carrier.ora) unpacks a
//    garbage payload pointer and panics lib/evm via huge-offset mload.
//    err_marker() compiles but is excluded from the spec until fixed.
// Ok paths and plain `match` (incl. tuple-from-match in content()) are correct.
error Failure;

contract ErrorUnionLocalAggregate {
    fn pick(flag: bool) -> !string | Failure {
        if (flag) {
            return "ora";
        }
        return Failure;
    }

    pub fn ok_len() -> u256 {
        try {
            let s: string = try pick(true);
            return s.len;
        } catch (e) {
            return 999;
        }
    }

    pub fn err_marker() -> u256 {
        try {
            let s: string = try pick(false);
            return s.len;
        } catch (e) {
            return 999;
        }
    }

    pub fn match_local() -> u256 {
        let r: Result<string, Failure> = Ok("ora");
        return match (r) {
            Ok(s) => s.len,
            Err(_) => 0,
        };
    }

    pub fn content() -> (u256, string) {
        let r: Result<string, Failure> = Ok("ora");
        return match (r) {
            Ok(s) => (1, s),
            Err(_) => (0, "none"),
        };
    }
}
