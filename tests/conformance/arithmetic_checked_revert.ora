// see FINDINGS.md#f-001 (requires not boundary-enforced; characterization rows in spec)
contract ArithmeticCheckedRevert {
    pub fn add(a: u256, b: u256) -> u256
        requires a <= 1000000
        requires b <= 1000000
    {
        return a + b;
    }

    pub fn div(a: u256, b: u256) -> u256
        requires b != 0
    {
        return a / b;
    }
}
