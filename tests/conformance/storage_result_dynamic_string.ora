error Failure;

contract StorageResultDynamicString {
    storage var saved: Result<string, Failure>;
    storage var marker: u256;

    pub fn init() {
        marker = 99;
    }

    pub fn set_ok(value: string) {
        saved = Ok(value);
    }

    pub fn set_err() {
        saved = Err(Failure());
    }

    pub fn len_or(fallback: u256) -> u256 {
        return match (saved) {
            Ok(value) => value.len,
            Err(_) => fallback,
        };
    }

    pub fn marker_value() -> u256 {
        return marker;
    }
}
