comptime const constants = @import("std/constants");

error InlineFailure;
error InlineOverflow;

contract SourceInlineConformance {
    storage var saved: u256;

    inline fn normalize(value: u256) -> u256 {
        return value;
    }

    inline fn choose(flag: bool, value: u256) -> u256 {
        if (flag) {
            return value;
        }
        return 0;
    }

    inline fn storeUnless(skip: bool, value: u256) {
        if (skip) {
            return;
        }
        saved = value;
    }

    inline fn chooseNested(flag: bool, other: bool, value: u256) -> u256 {
        if (flag) {
            if (other) {
                return value;
            }
            return 1;
        }
        return 0;
    }

    inline fn chooseMode(comptime mode: u256) -> u256 {
        var out: u256 = 0;
        comptime {
            if (mode == 1) {
                out = 7;
            } else {
                out = 9;
            }
        }
        return out;
    }

    inline fn chooseImplicit(mode: u256) -> u256 {
        var out: u256 = 0;
        comptime {
            if (mode == 1) {
                out = 7;
            } else {
                out = 9;
            }
        }
        return out;
    }

    inline fn chooseLiteralFlag(flag: bool) -> u256 {
        var out: u256 = 0;
        comptime {
            if (flag) {
                out = 11;
            } else {
                out = 12;
            }
        }
        return out;
    }

    inline fn structuredChoice(flag: bool, tag: u256, value: u256) -> u256 {
        var out: u256 = 0;
        if (flag) {
            out = value;
        } else {
            out = 4;
        }
        switch (tag) {
            1 => {
                out = out;
            }
            else => {
                out = 9;
            }
        }
        return out;
    }

    inline fn countThree() -> u256 {
        var count: u256 = 0;
        while (count < 3)
            invariant count <= 3
        {
            count = count + 1;
        }
        return count;
    }

    inline fn writeSaved(value: u256) {
        saved = normalize(value);
    }

    inline fn observeTwice(value: u256) -> u256 {
        if (value == value) {
            return 14;
        }
        return 0;
    }

    inline fn maybeInline(flag: bool) -> !u256 | InlineFailure {
        if (flag) {
            return 23;
        }
        return InlineFailure;
    }

    inline fn maybeResult(flag: bool, value: u256) -> Result<u256, InlineFailure> {
        if (flag) {
            return Ok(value);
        }
        return Err(InlineFailure());
    }

    inline fn checkTwo(first: bool, second: bool) -> !u256 | InlineFailure {
        if (first) {
            return InlineFailure;
        }
        if (second) {
            return InlineFailure;
        }
        return 37;
    }

    inline fn checkedAddInline(current: u256, delta: u256) -> !u256 | InlineOverflow {
        if (current > constants.U256_MAX - delta) {
            return InlineOverflow;
        }
        return current + delta;
    }

    inline fn checkedSignedAddInline(current: i256, delta: i256) -> !i256 | InlineOverflow {
        if (delta > 0 && current > constants.I256_MAX - delta) {
            return InlineOverflow;
        }
        if (delta < 0 && current < constants.I256_MIN - delta) {
            return InlineOverflow;
        }
        return current + delta;
    }

    fn sideEffectArg() -> u256
        requires(saved < constants.U256_MAX)
        ensures result == 7
    {
        saved = saved + 1;
        return 7;
    }

    pub fn set(value: u256) {
        writeSaved(value);
    }

    pub fn get() -> u256 {
        return saved;
    }

    pub fn echo(value: u256) -> u256 {
        return normalize(value);
    }

    pub fn chooseValue(flag: bool, value: u256) -> u256 {
        return choose(flag, value);
    }

    pub fn maybeSet(skip: bool, value: u256) {
        storeUnless(skip, value);
    }

    pub fn nestedChoice(flag: bool, other: bool, value: u256) -> u256 {
        return chooseNested(flag, other, value);
    }

    pub fn modeOne() -> u256 {
        return chooseMode(1);
    }

    pub fn modeTwo() -> u256 {
        return chooseMode(2);
    }

    pub fn implicitOne() -> u256 {
        return chooseImplicit(1);
    }

    pub fn implicitTwo() -> u256 {
        return chooseImplicit(2);
    }

    pub fn literalFlagTrue() -> u256 {
        return chooseLiteralFlag(true);
    }

    pub fn literalFlagFalse() -> u256 {
        return chooseLiteralFlag(false);
    }

    pub fn structured(flag: bool, tag: u256, value: u256) -> u256 {
        return structuredChoice(flag, tag, value);
    }

    pub fn loopThree() -> u256 {
        return countThree();
    }

    pub fn singleEval() -> u256 {
        saved = 0;
        return observeTwice(sideEffectArg());
    }

    pub fn inlineTryOk() -> u256 {
        try {
            let value: u256 = try maybeInline(true);
            return value;
        } catch {
            return 999;
        }
    }

    pub fn inlineTryErr() -> u256 {
        try {
            let value: u256 = try maybeInline(false);
            return value;
        } catch {
            return 999;
        }
    }

    pub fn inlinePropagateErr() -> !u256 | InlineFailure {
        let value: u256 = try maybeInline(false);
        return value;
    }

    pub fn inlineResult(flag: bool, value: u256) -> !u256 | InlineFailure {
        let out: u256 = try maybeResult(flag, value);
        return out;
    }

    pub fn inlineCheckTwo(first: bool, second: bool) -> !u256 | InlineFailure {
        let out: u256 = try checkTwo(first, second);
        return out;
    }

    pub fn checkedAdd(current: u256, delta: u256) -> !u256 | InlineOverflow {
        let out: u256 = try checkedAddInline(current, delta);
        return out;
    }

    pub fn checkedSignedAdd(current: i256, delta: i256) -> !i256 | InlineOverflow {
        let out: i256 = try checkedSignedAddInline(current, delta);
        return out;
    }
}
