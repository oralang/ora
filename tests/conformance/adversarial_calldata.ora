// Target for adversarial raw-calldata cases (T2). A single public fn taking a
// dynamic argument exposes the dispatcher's calldata bounds/offset checks.
contract AdversarialCalldata {
    pub fn echo_len(s: string) -> u256 {
        return s.len;
    }

    pub fn add(a: u256, b: u256) -> u256
        requires a <= 1000000
        requires b <= 1000000
    {
        return a + b;
    }
}
